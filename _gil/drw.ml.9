#load "svg.cma"
let env = ref []
let push_env prm =
  env := prm :: !env
let get_env () = !env
let pop_env () =
  match !env with
  | prm :: _ -> prm
  | [] -> ("void", [])
let shift_env () =
  match !env with
  | prm :: env_ -> env := env_ ; prm
  | [] -> assert false
