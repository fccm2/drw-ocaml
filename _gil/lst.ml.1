let ass_repl v0 n0 ass0 =
  let rec aux acc ass =
    match ass with
    | (v,n)::ass when v=v0 -> let ass = (v,n0)::ass in List.rev_append acc ass
    | (vn)::ass -> aux (vn::acc) ass
    | [] -> ass0
  in
  aux [] ass0
let add_last v0 lst =
  let rec aux acc lst =
    match lst with
    | v::lst -> aux (v::acc) lst
    | [] -> List.rev(v0::acc)
  in
  aux [] lst
let mv_fst v0 lst0 =
  let rec aux acc lst =
    match lst with
    | v::lst when v=v0 -> let acc = v0::acc in List.rev_append acc lst
    | v::lst -> aux (v::acc) lst
    | [] -> lst0
  in
  aux [] lst0
let mem_ass v0 lst =
  let rec aux lst =
    match lst with
    | ((v,_)as vn)::lst when v=v0 -> (vn)
    | _::lst -> aux lst
    | [] -> raise Not_found
  in
  aux lst
let mem_ass_rem v0 lst =
  let rec aux acc lst =
    match lst with
    | ((v,_)as vn)::lst when v=v0 -> (vn, List.rev_append acc lst)
    | vn::lst -> aux (vn::acc) lst
    | [] -> raise Not_found
  in
  aux [] lst
let lst_rem v0 lst =
  let rec aux acc lst =
    match lst with
    | v::lst when v=v0 -> (v, List.rev_append acc lst)
    | v::lst -> aux (v::acc) lst
    | [] -> raise Not_found
  in
  aux [] lst
let rem_f f lst =
  let rec aux acc lst =
    match lst with
    | v::lst when (f v) -> (v, List.rev_append acc lst)
    | v::lst -> aux (v::acc) lst
    | [] -> raise Not_found
  in
  aux [] lst
let shift_lft lst =
  match lst with
  | v::lst -> List.rev(v::(List.rev lst))
  | [] -> []
let shift_rgh lst =
  match List.rev lst with
  | v::lst -> v::(List.rev lst)
  | [] -> []
